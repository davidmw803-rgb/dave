# Supabase project (the "Dave" project — id shwylcfhxmrunwjbunnf).
# URL is fine to expose. Service-role key must never leak to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://shwylcfhxmrunwjbunnf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-from-supabase-dashboard

# Shared-secret token for the dashboard. Generate with:
#   openssl rand -hex 16
# Open the dashboard once at https://<host>/login?token=<value>; the cookie then
# authorises the browser for 30 days.
DASHBOARD_TOKEN=replace-me-with-openssl-rand-hex-16
