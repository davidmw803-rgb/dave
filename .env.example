# ============================================================================
# Supabase
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-start

# ============================================================================
# Unusual Whales API
# Get key from https://unusualwhales.com/api
# ============================================================================
UW_API_KEY=
UW_API_BASE_URL=https://api.unusualwhales.com/api

# ============================================================================
# Price provider (Session 5+)
# Set PRICE_PROVIDER to: mock | polygon | databento
# ============================================================================
PRICE_PROVIDER=mock
POLYGON_API_KEY=
DATABENTO_API_KEY=

# ============================================================================
# Anthropic (for narratives + weekly reports, Session 6+)
# ============================================================================
ANTHROPIC_API_KEY=

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Access gate (custom password page)
# APP_PASSWORD: the password the single operator types on /login.
# SESSION_SECRET: random hex string used to sign the session cookie.
#   Generate with: openssl rand -hex 32
# ============================================================================
APP_PASSWORD=
SESSION_SECRET=
