# ============================================================================
# Supabase
# Used by the Polymarket paper-trade dashboard (/, /trades, /markets/[slug], /strategy).
# - NEXT_PUBLIC_* keys are safe to expose to the browser (Realtime + client reads).
# - SUPABASE_SERVICE_ROLE_KEY is SERVER-ONLY — never import into client code.
#   Consumed by /api/live-mids and server components (lib/supabase/admin.ts).
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-start

# ============================================================================
# Unusual Whales API
# Get key from https://unusualwhales.com/api
# ============================================================================
UW_API_KEY=
UW_API_BASE_URL=https://api.unusualwhales.com/api

# ============================================================================
# Price provider (Session 5+)
# Set PRICE_PROVIDER to: mock | polygon | databento
# ============================================================================
PRICE_PROVIDER=mock
POLYGON_API_KEY=
DATABENTO_API_KEY=

# ============================================================================
# Anthropic (for narratives + weekly reports, Session 6+)
# ============================================================================
ANTHROPIC_API_KEY=

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
